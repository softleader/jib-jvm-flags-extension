#!/usr/bin/env groovy

currentBuild.description = "${ref} -> ${tag}"
// https://semver.org/#is-there-a-suggested-regular-expression-regex-to-check-a-semver-string
def semverPattern = /^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)(?:-((?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\.(?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\+([0-9a-zA-Z-]+(?:\.[0-9a-zA-Z-]+)*))?$/

pipeline {
  agent {
    kubernetes {
      cloud 'SLKE'
      defaultContainer 'maven'
      yaml """
kind: Pod
spec:
  # All containers should have the same UID
  securityContext:
    runAsUser: 0
  containers:
  - name: maven
    image: harbor.softleader.com.tw/library/maven:3-eclipse-temurin-11
    imagePullPolicy: Always
    command: ['cat']
    tty: true
    resources:
      limits:
        memory: "1Gi"
        cpu: "2"
    volumeMounts:
    - name: m2
      mountPath: /root/.m2
    - name: gpg
      mountPath: /var/gpg
  - name: git
    image: harbor.softleader.com.tw/library/git:2
    command: ['cat']
    tty: true
    resources:
      limits:
        memory: "100Mi"
        cpu: "100m"
  volumes:
  - name: m2
    persistentVolumeClaim:
      claimName: m2-claim
  - name: gpg
    persistentVolumeClaim:
      claimName: gpg-claim
"""
    }
  }

  environment {
    MAVEN_OPTS="-Xmx768m -XX:MaxMetaspaceSize=128m"
  }

  stages {

    stage('Setup') {
      steps {
        sh 'printenv'
        sh 'java -version'
        sh 'mvn --version'
        echo "${params}"
      }
    }

    // 前置檢查 (sanity): release-please-action 已建好 tag + 非 draft GitHub Release,
    // 此處只驗 tag 字串符合 semver, 防呆參數誤打
    stage ('Preflight Checks') {
      steps {
        script {
          def isSemVer = ("${tag}" ==~ semverPattern)
          if (!isSemVer) {
            error "Tag must matches semantic versioning 2 (https://semver.org/) but got: ${tag}";
          }
        }
      }
    }

    stage ('Publish Release') {
      steps {
        sh """
        echo /var/gpg/softleader.passphrase | gpg --batch --yes --import /var/gpg/softleader.key
        make release
        """
        // Gradle 模組透過 nmcp plugin 上傳至 Sonatype Central Portal,
        // 對齊 maven 側 central-publishing-maven-plugin 的行為.
        // Sonatype 帳密由 build.gradle 從 ~/.m2/settings.xml <server id="central"> 解密讀取
        // (與 maven 同源, plexus-sec-dispatcher 解 settings-security.xml), 不需 Jenkins credential.
        // GPG_PASSPHRASE 餵給 build.gradle signing 區塊的 signing.gnupg.passphrase project property,
        // 讓 useGpgCmd() 在 --batch 模式下能取得 passphrase (Gradle 不會自動 prime gpg-agent cache).
        dir('gradle') {
          // --no-daemon: short-lived CI pod throws the daemon away, no point paying startup
          sh '''
          export GPG_PASSPHRASE="$(cat /var/gpg/softleader.passphrase)"
          ./gradlew publishAllPublicationsToCentralPortal --no-daemon
          '''
        }
      }
    }
  }

  post {
    failure {
      slackSend(
        color: "danger",
        channel: "@matt",
        message: "Attention @here, The pipeline <$BUILD_URL|*${env.JOB_NAME} #${env.BUILD_NUMBER}*> has failed! :omg:\n>Last commit by ${env.LAST_COMMIT_AUTHOR_NAME} (${env.LAST_COMMIT_AUTHOR_EMAIL}) @ ${env.LAST_COMMIT_TIME}"
      )
    }
  }
}
